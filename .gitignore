# ── Rust build artifacts ────────────────────────────────────────────
target/
**/target/

# Cargo.lock in fuzz subprojects (each fuzz crate has its own dep tree,
# resolved automatically; not part of workspace lockfile)
crates/*/fuzz/Cargo.lock

# ── Generated / machine-local indexes ───────────────────────────────
# CodeGraph MCP AST index (per-machine)
.codegraph/
# OhMyOpenCode agent state
.sisyphus/
# OhMyOpenCode planning dir
.omo/

# ── Test framework artifacts ───────────────────────────────────────
# proptest crash/regression storage
**/proptest-regressions/
# proptest regression files (individual)
**/*.proptest-regressions
# cargo-fuzz crash inputs / corpus deltas
**/fuzz/artifacts/
# (also covered by target/ above, kept for clarity)
**/fuzz/target/

# ── Dev scripts (temp validation, not distribution) ──────────────────
scripts/*.py

# ── Generated validation reports ───────────────────────────────────
docs/sup-validation-report.md

# ── Coverage reports (regenerable) ────────────────────────────────
coverage/
*.profraw
*.profdata

# ── Repo-level build/test outputs ──────────────────────────────────
# any .sup file anywhere
*.sup
# root-level .sup (test artifacts)
/*.sup

# ── Agent / planning docs (ephemeral, regenerate per phase) ───────
phase*-plan.md
phase*-spec.md
phase*-spec.html
ass2sup-spec.html
easyavs2bdnxml-analysis-report.html

# ── Editor / IDE state ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.swn
*~
# emacs autosave (escape # to match literal hashes)
\#*#
# emacs lockfile (escape # to match literal hash)
.\#*
*.bak

# ── Patch / merge artifacts ───────────────────────────────────────
*.orig
*.rej
*.patch
*.tmp

# ── Environment files ──────────────────────────────────────────────
.env
.env.local
# direnv
.envrc

# ── OS metadata ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Python virtual environments / bytecode ─────────────────────────
.venv/
.venv*/
__pycache__/
*.pyc
*.pyo

# ── Local dev config (per-machine, not shared) ─────────────────────
.localref/
.opencode/
.output/

# ── Cross-compilation cache (xwin) ─────────────────────────────────
.xwin-cache/
output/

# ── ass2sup-libass local build files ──────────────────────────────
ass2sup-libass/links/

# Performance test artifacts
.perf_test/
